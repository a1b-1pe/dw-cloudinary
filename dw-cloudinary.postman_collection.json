{
  "info": {
    "name": "DW Cloudinary API",
    "_postman_id": "dw-cloudinary-collection",
    "description": "Postman collection for DW Cloudinary Spring Boot service",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "cloudUrl",
      "value": "https://dw-cloudinary-5718687f18bb.herokuapp.com",
      "type": "string"
    },
    {
      "key": "publicId",
      "value": "sample_public_id",
      "type": "string"
    },
    {
      "key": "bearerToken",
      "value": "",
      "type": "string",
      "description": "JWT token obtained from ld-authorization-service /auth/login"
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      { "key": "token", "value": "{{bearerToken}}", "type": "string" }
    ]
  },
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{cloudUrl}}/actuator/health",
              "host": ["{{cloudUrl}}"],
              "path": ["actuator", "health"]
            },
            "description": "No auth required. Returns {\"status\":\"UP\"} when the service is healthy."
          }
        }
      ]
    },
    {
      "name": "Image",
      "item": [
        {
          "name": "Upload Image",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": "",
                  "description": "Image file (jpg, png, gif, webp, svg)"
                }
              ]
            },
            "url": {
              "raw": "{{cloudUrl}}/v1/cloudinary/image",
              "host": ["{{cloudUrl}}"],
              "path": ["v1", "cloudinary", "image"]
            },
            "description": "Upload an image to Cloudinary. Returns Cloudinary upload response map."
          }
        },
        {
          "name": "Update Image by Public ID",
          "request": {
            "method": "PUT",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": "",
                  "description": "Replacement image file"
                }
              ]
            },
            "url": {
              "raw": "{{cloudUrl}}/v1/cloudinary/image/id/{{publicId}}",
              "host": ["{{cloudUrl}}"],
              "path": ["v1", "cloudinary", "image", "id", "{{publicId}}"]
            },
            "description": "Replace an existing image by its Cloudinary public_id."
          }
        },
        {
          "name": "Get Image Thumbnail URL",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{cloudUrl}}/v1/cloudinary/image/id/{{publicId}}",
              "host": ["{{cloudUrl}}"],
              "path": ["v1", "cloudinary", "image", "id", "{{publicId}}"]
            },
            "description": "Returns a 150x150 thumbnail URL string for the given image public_id."
          }
        },
        {
          "name": "Delete Image by Public ID",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{cloudUrl}}/v1/cloudinary/image/id/{{publicId}}",
              "host": ["{{cloudUrl}}"],
              "path": ["v1", "cloudinary", "image", "id", "{{publicId}}"]
            },
            "description": "Deletes an image from Cloudinary by its public_id."
          }
        }
      ]
    },
    {
      "name": "PDF",
      "item": [
        {
          "name": "Upload PDF",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": "",
                  "description": "PDF file only"
                }
              ]
            },
            "url": {
              "raw": "{{cloudUrl}}/v1/cloudinary/pdf",
              "host": ["{{cloudUrl}}"],
              "path": ["v1", "cloudinary", "pdf"]
            },
            "description": "Upload a PDF document to Cloudinary. Returns JSON response from Cloudinary."
          }
        }
      ]
    },
    {
      "name": "ZIP",
      "item": [
        {
          "name": "Upload ZIP",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": "",
                  "description": "ZIP archive"
                }
              ]
            },
            "url": {
              "raw": "{{cloudUrl}}/v1/cloudinary/zip",
              "host": ["{{cloudUrl}}"],
              "path": ["v1", "cloudinary", "zip"]
            },
            "description": "Upload a ZIP file to Cloudinary under the 'archives' folder."
          }
        }
      ]
    },
    {
      "name": "Video",
      "item": [
        {
          "name": "Upload Video",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": "",
                  "description": "Video file (mp4, mov, avi, webm, mpeg)"
                }
              ]
            },
            "url": {
              "raw": "{{cloudUrl}}/v1/cloudinary/video",
              "host": ["{{cloudUrl}}"],
              "path": ["v1", "cloudinary", "video"]
            },
            "description": "Upload a video to Cloudinary. Eager transformations are applied asynchronously."
          }
        },
        {
          "name": "Get Video Thumbnail URL",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{cloudUrl}}/v1/cloudinary/video/id/{{publicId}}",
              "host": ["{{cloudUrl}}"],
              "path": ["v1", "cloudinary", "video", "id", "{{publicId}}"]
            },
            "description": "Returns a 200x150 PNG thumbnail URL for the given video public_id."
          }
        }
      ]
    }
  ]
}
